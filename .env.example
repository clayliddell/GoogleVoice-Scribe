GV_SERVICE_HOST=127.0.0.1
GV_SERVICE_PORT=8765
GV_RECORDINGS_DIR=%USERPROFILE%\Documents\Google Voice Transcripts

GV_MODEL_NAME=ibm-granite/granite-speech-4.1-2b-plus
GV_TRANSCRIBE=1
GV_SEGMENT_SECONDS=240
GV_MAX_NEW_TOKENS=2000
GV_REFERENCE_MAX_NEW_TOKENS=128

GV_TITLE_BACKEND=llama_cpp
GV_TITLE_MODEL_NAME=unsloth/gemma-4-E4B-it-GGUF
GV_TITLE_GGUF_FILENAME=gemma-4-E4B-it-Q4_K_M.gguf
GV_TITLE_CONTEXT_TOKENS=2048
GV_TITLE_GPU_LAYERS=-1
GV_TITLE_CACHE_TYPE_K=q8_0
GV_TITLE_CACHE_TYPE_V=q8_0
GV_TITLE_FLASH_ATTN=1
GV_KEEP_TITLE_MODEL=1
GV_FORCE_CPU=0

GV_HF_LOCAL_FIRST=1
GV_HF_LOCAL_FILES_ONLY=0

GV_COMPRESS_AUDIO=1
GV_KEEP_WAV_FILES=0
GV_COMPRESSED_AUDIO_FORMAT=opus
GV_OPUS_BITRATE=24k

GV_INCREMENTAL_TRANSCRIPTION=1
GV_INCREMENTAL_REFERENCE_TRANSCRIPTION=1
GV_INCREMENTAL_SEGMENT_SECONDS=60
GV_INCREMENTAL_BOUNDARY_SEARCH_SECONDS=3
GV_INCREMENTAL_MAX_SEGMENT_SECONDS=75
GV_INCREMENTAL_OVERLAP_SECONDS=1.5
GV_INCREMENTAL_SILENCE_RMS=0.0025
GV_INCREMENTAL_SILENCE_WINDOW_MS=250
GV_WARM_GRANITE_ON_CALL_START=1

GV_SPEAKER_REFERENCE_MODE=sampled
GV_SPEAKER_REFERENCE_SECONDS=60
GV_SPEAKER_REFERENCE_WINDOW_SECONDS=20
GV_SPEAKER_REFERENCE_MIN_RMS=0.003
